<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous">
        <link rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
        <title>Add Product </title>
    </head>
    <body>
        <%- include('includes/navbar.ejs') %>
        <div class="container mt-4 form-container w-25">
            <form action="/add-product" method="post">
            <h2 class="fw-bold fs-3 m-4 mb-2">Add Product</h2>
            <div class="form-control m3-p-4">
                <div class="row">
                    <div class="col-8 mt-2 mb-3">
                        <label class="form-label fs-4" for="productname">Product
                            Name</label>
                        <input type="text" name="productname"
                            class="form-control" required>
                    </div>
                    <div class="col-4 mt-2 mb-3">
                        <label class="form-label fs-4" for="price">Price</label>
                        <input type="text" name="price" class="form-control" required>
                    </div>

                </div>
                <div class="my-3">
                    <label class="form-label fs-4" for="image">Select
                        Image</label>
                    <input type="file" name="image" class="form-control" required>
                </div>
            </div>

            <button class="btn btn-primary fs-4 ml-1 mt-2 w-100"
                type="submit">Add Product</button>
                </form>
        </div>
    </body>
</html>